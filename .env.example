# Copy to .env and fill in. Never commit .env.

# Local dev — path is relative to the prisma/ folder (same folder as schema.prisma), so this creates prisma/dev.db
DATABASE_URL="file:./dev.db"

# Docker / Dokploy (example): mount a persistent volume on the container, then use an absolute file URL, e.g.:
# DATABASE_URL="file:/data/prisma/prod.db"
# Create the folder on first deploy; run `npx prisma db push` once against that URL (or use a one-off container).

# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Local dev
NEXTAUTH_URL="http://localhost:3000"

# Production (Dokploy / your real domain) — must match the URL users use, including https://
# NEXTAUTH_URL="https://your-domain.com"

# Stripe (supporter subscription) — paste from dashboard.stripe.com (test keys are fine on your computer)
# Secret key: Developers → API keys → Secret key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=""
# Monthly price id from the product’s $1.99 price (price_... not prod_...)
STRIPE_PRICE_ID=""
# Optional — only if you add a webhook at /api/stripe/webhook (keeps DB in sync on cancel/renew without a return visit)
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Enable Customer portal: Billing → Customer portal (needed for /unenroll)

# VA Facilities API (Lighthouse) — used by `npm run build:va-state-data` to fill real phones/websites.
# Request a key at https://developer.va.gov/ — use production for the full national dataset.
# VA_API_KEY=""
# Optional: defaults to production v1 URL; use sandbox for limited test data.
# VA_FACILITIES_BASE="https://sandbox-api.va.gov/services/va_facilities/v1"
