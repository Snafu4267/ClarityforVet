# Copy to .env and fill in. Never commit .env.

# Local dev (SQLite file next to the app)
DATABASE_URL="file:./prisma/dev.db"

# Docker / Dokploy (example): mount a persistent volume, then point at an absolute path inside the container, e.g.:
# DATABASE_URL="file:/data/prisma/prod.db"
# Create the folder on first deploy; run `npx prisma db push` once against that URL (or use a one-off container).

# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Local dev
NEXTAUTH_URL="http://localhost:3000"

# Production (Dokploy / your real domain) — must match the URL users use, including https://
# NEXTAUTH_URL="https://your-domain.com"

# VA Facilities API (Lighthouse) — used by `npm run build:va-state-data` to fill real phones/websites.
# Request a key at https://developer.va.gov/ — use production for the full national dataset.
# VA_API_KEY=""
# Optional: defaults to production v1 URL; use sandbox for limited test data.
# VA_FACILITIES_BASE="https://sandbox-api.va.gov/services/va_facilities/v1"
